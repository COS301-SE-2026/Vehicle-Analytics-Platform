# .env.example - THIS FILE IS SAFE TO COMMIT
# It serves as a template. Do NOT put real AWS keys or production passwords here.

# Local Database (These match the local docker-compose.yml so they are safe)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleet_analytics
DB_USER=admin
DB_PASSWORD=localdev

# AWS (For the live Kinesis stream - Replace with real keys in your local .env file)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_real_access_key_here
AWS_SECRET_ACCESS_KEY=your_real_secret_key_here
STREAM_NAME=capstone-analytics-kinesisstream

# API & Frontend
API_BASE_URL=http://localhost:4000
VITE_MAPBOX_TOKEN=your_mapbox_token_here