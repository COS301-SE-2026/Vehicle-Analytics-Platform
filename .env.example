cat > .env.example << 'EOF'
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE — EC2 TimescaleDB
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DB_HOST=
DB_PORT=5432
DB_NAME=fleet_analytics
DB_USER=
DB_PASSWORD=

# Full connection string (alternative to individual vars)
DATABASE_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AWS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AWS_REGION=af-south-1
AWS_PROFILE=kilimanjaro

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# KINESIS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
STREAM_NAME=capstone-analytics-kinesisstream

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MAPBOX
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_MAPBOX_TOKEN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# API
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
API_BASE_URL=http://localhost:4000
API_PORT=4000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUTH
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
JWT_SECRET=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
EOF